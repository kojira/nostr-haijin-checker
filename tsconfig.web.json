{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "verbatimModuleSyntax": false
  },
  "include": [
    "src/web/**/*.ts",
    "src/nostr/**/*.ts",
    "src/scoring/**/*.ts",
    "src/types.ts",
    "vite.config.ts"
  ],
  "exclude": ["node_modules", "dist", "dist-web"]
}
